#!/bin/bash
#
# .dotenv
#
# Setup machine-independent, shell-independent environment.
# Sourced for all sessions.
#
# Machine-specific changes can be placed in ~/.dotenv_local
# Note there are also .dotshell, .dotshell_local
#
# Global profile configs (such as /etc/profile) should be sourced
# before this file.
#

OSNAME=$(uname -s)

# load rustup
# shellcheck disable=SC1091
[[ -f "$HOME/.cargo/env" ]] && . "$HOME/.cargo/env"

# 256 color terminal
export TERM='screen-256color'

# User bin directory
if [[ -d "$HOME/.dotbin" ]]; then
    export PATH="$HOME/.dotbin:$PATH"
fi

# Alternative bin directory
if [[ -d "$HOME/Drive/code" ]]; then
    export PATH="$HOME/Drive/code:$PATH"
fi

if [[ $OSNAME == "Darwin" ]]; then
    ## macOS installation ##

    # homebrew apple silicon
    if [[ -d '/opt/homebrew/bin/' ]]; then
        eval "$(/opt/homebrew/bin/brew shellenv)"
    fi

    # iCloud Drive bin directory
    if [[ -d "$HOME/Library/Mobile Documents/com~apple~CloudDocs/Drive/code" ]]; then
        export PATH="$HOME/Library/Mobile Documents/com~apple~CloudDocs/Drive/code:$PATH"
    fi

    # disable macOS bash deprecation warning
    export BASH_SILENCE_DEPRECATION_WARNING=1

    # export values to entire system
    launchctl setenv PATH "$PATH"

else
    ## linux installation ##

    # keychain
    if [[ -x "$(command -v keychain)" ]]; then
        eval "$(keychain --eval --agents ssh --quiet --ignore-missing id_rsa id_ed25519 id_ed25519_git)"
    fi

fi
